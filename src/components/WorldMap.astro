---
import data from '../data/data.json';

const { mapSection, cities, flightPath, segmentDuration } = data;

// 构建路径数据 - 三段贝塞尔曲线
const cityMap = Object.fromEntries(cities.map(c => [c.id, c]));
const pathSegments = [];
for (let i = 0; i < flightPath.length - 1; i++) {
  const from = cityMap[flightPath[i]];
  const to = cityMap[flightPath[i + 1]];
  if (from && to) {
    // 控制点 - 形成弧形
    const midX = (from.cx + to.cx) / 2;
    const midY = Math.min(from.cy, to.cy) - 60; // 向上弯曲
    pathSegments.push({
      d: `M ${from.cx} ${from.cy} Q ${midX} ${midY} ${to.cx} ${to.cy}`,
      from: from.id,
      to: to.id,
    });
  }
}

// 完整路径 - 用于飞机沿路径运动
const fullPathD = pathSegments.map((seg, i) => i === 0 ? seg.d : seg.d.replace(/^M [^Q]+Q/, 'Q')).join(' ');
const totalDuration = (flightPath.length - 1) * segmentDuration;
---

<section class="relative min-h-screen flex flex-col items-center justify-center px-6 py-20">

  <!-- 标题 -->
  <h2 class="text-3xl md:text-5xl font-serif text-tiffany font-bold mb-12 tracking-wide">
    {mapSection.title}
  </h2>

  <!-- 地图容器 -->
  <div class="relative w-full max-w-5xl glass rounded-3xl p-8 md:p-12">

    <svg
      viewBox="0 0 1000 500"
      class="w-full h-auto"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label="A simplified Eurasia map showing Beijing, Tianjin, and Budapest with a paper plane flying between them"
    >
      <!-- Defs -->
      <defs>
        <!-- Eurasia simplified outline path -->
        <path id="flight-full-path" d={fullPathD} fill="none" />

        <!-- 复古纸飞机 SVG -->
        <g id="paper-plane">
          <path
            d="M 0,0 L 24,8 L 0,16 L 6,8 Z"
            fill="#D4A373"
            stroke="#1E3A5F"
            stroke-width="0.5"
            stroke-linejoin="round"
            transform="translate(-12,-8)"
          />
          <line x1="-6" y1="0" x2="0" y2="0" stroke="#D4A373" stroke-width="0.8" stroke-dasharray="2,2" opacity="0.5"/>
        </g>
      </defs>

      <!-- Eurasia 大陆轮廓(极简、文体化、抽象) -->
      <g stroke="#0ABAB5" stroke-width="1" fill="rgba(10, 186, 181, 0.04)" stroke-opacity="0.35" stroke-linejoin="round" stroke-linecap="round">
        <!-- Europe rough outline -->
        <path d="M 80 180 Q 100 160 140 165 Q 180 155 220 170 Q 260 165 290 180 Q 320 200 340 220 Q 360 250 350 280 Q 330 310 300 320 Q 260 330 220 320 Q 180 310 140 295 Q 100 280 80 240 Q 70 200 80 180 Z" />
        <!-- Asia rough outline -->
        <path d="M 340 200 Q 400 175 480 180 Q 560 170 640 185 Q 720 195 800 210 Q 870 230 900 270 Q 905 320 880 360 Q 840 380 780 375 Q 700 370 620 360 Q 540 355 460 345 Q 400 335 360 315 Q 330 290 335 250 Q 335 220 340 200 Z" />
      </g>

      <!-- 飞行轨迹路径(虚线) -->
      {pathSegments.map((seg, i) => (
        <path
          d={seg.d}
          fill="none"
          stroke="#0ABAB5"
          stroke-width="1.2"
          stroke-dasharray="3,4"
          stroke-opacity="0.35"
          stroke-linecap="round"
        />
      ))}

      <!-- 城市圆点 + 标签 -->
      {cities.map(city => (
        <g class="city-group" data-city={city.id}>
          <!-- Pulsing outer ring -->
          <circle
            cx={city.cx}
            cy={city.cy}
            r="14"
            fill={city.color}
            fill-opacity="0.2"
          >
            <animate attributeName="r" values="14;22;14" dur="3s" repeatCount="indefinite" />
            <animate attributeName="fill-opacity" values="0.3;0;0.3" dur="3s" repeatCount="indefinite" />
          </circle>
          <!-- Main dot -->
          <circle
            class="city-dot"
            cx={city.cx}
            cy={city.cy}
            r="7"
            fill={city.color}
            stroke="white"
            stroke-width="2"
            data-hover-text={city.hoverText}
            data-city-id={city.id}
          />
          <!-- Label -->
          <text
            x={city.cx + 14}
            y={city.cy + 5}
            font-family="Inter, sans-serif"
            font-size="14"
            font-weight="500"
            fill="#374151"
          >
            {city.name} · {city.label}
          </text>
        </g>
      ))}

      <!-- 小飞机 -->
      <g id="moving-plane">
        <use href="#paper-plane">
          <animateMotion
            dur={`${totalDuration}ms`}
            repeatCount="indefinite"
            rotate="auto"
            path={fullPathD}
          />
        </use>
      </g>
    </svg>

    <!-- Hover tooltip (动态显示) -->
    <div
      id="city-tooltip"
      class="absolute pointer-events-none opacity-0 transition-opacity duration-200 glass rounded-full px-4 py-2 text-sm font-sans text-gray-700 shadow-md"
      style="transform: translate(-50%, -130%);"
    >
      <span id="tooltip-text"></span>
    </div>

  </div>

  <!-- Caption below -->
  <p class="mt-8 text-sm font-sans text-gray-500 italic max-w-md text-center">
    "我们经常说不知道去做什么,但是我们总知道人是最重要的。"
  </p>

</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cityDots = document.querySelectorAll('.city-dot');
    const tooltip = document.getElementById('city-tooltip');
    const tooltipText = document.getElementById('tooltip-text');
    const mapContainer = tooltip?.parentElement;

    cityDots.forEach(dot => {
      dot.addEventListener('mouseenter', (e) => {
        const target = e.target as SVGCircleElement;
        const hoverText = target.getAttribute('data-hover-text');
        if (tooltip && tooltipText && hoverText) {
          tooltipText.textContent = hoverText;
          // 计算 tooltip 的位置(相对 SVG)
          const svg = target.ownerSVGElement;
          const containerRect = mapContainer?.getBoundingClientRect();
          if (svg && containerRect) {
            const rect = target.getBoundingClientRect();
            const x = rect.left + rect.width / 2 - containerRect.left;
            const y = rect.top - containerRect.top;
            tooltip.style.left = `${x}px`;
            tooltip.style.top = `${y}px`;
            tooltip.style.opacity = '1';
          }
        }
      });

      dot.addEventListener('mouseleave', () => {
        if (tooltip) {
          tooltip.style.opacity = '0';
        }
      });
    });
  });
</script>
