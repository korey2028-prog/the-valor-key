---
import data from '../data/data.json';

const { hungarianText, chineseTranslation, englishTranslation } = data.hiddenMessage;
---

<!-- Hidden message dialog - triggered by clicking the key icon in Hero -->
<div
  id="hidden-message-dialog"
  class="hidden fixed inset-0 z-50 flex items-center justify-center opacity-0 transition-opacity duration-500 px-4"
  style="background: rgba(0, 0, 0, 0.3); backdrop-filter: blur(8px);"
  role="dialog"
  aria-modal="true"
  aria-labelledby="hidden-message-title"
>
  <div class="glass rounded-3xl max-w-lg w-full p-8 md:p-12 text-center relative">

    <!-- Close button -->
    <button
      id="close-message"
      class="absolute top-4 right-4 text-gray-400 hover:text-gray-700 transition-colors"
      aria-label="Close"
    >
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>

    <!-- Decorative key icon top -->
    <div class="flex justify-center mb-6">
      <svg class="w-12 h-12 text-tiffany" viewBox="0 0 64 64" fill="none">
        <circle cx="20" cy="32" r="10" stroke="currentColor" stroke-width="3" fill="none"/>
        <line x1="30" y1="32" x2="56" y2="32" stroke="currentColor" stroke-width="3"/>
        <line x1="46" y1="32" x2="46" y2="42" stroke="currentColor" stroke-width="3"/>
        <line x1="52" y1="32" x2="52" y2="40" stroke="currentColor" stroke-width="3"/>
      </svg>
    </div>

    <!-- Hungarian -->
    <p id="hidden-message-title" class="text-3xl md:text-4xl font-serif text-tiffany font-bold mb-3">
      {hungarianText}
    </p>

    <!-- English -->
    <p class="text-base md:text-lg font-sans text-gray-500 italic mb-2">
      {englishTranslation}
    </p>

    <!-- Chinese -->
    <p class="text-lg md:text-xl font-cn text-pink-soft font-medium">
      {chineseTranslation}
    </p>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const dialog = document.getElementById('hidden-message-dialog');
    const closeBtn = document.getElementById('close-message');

    function closeDialog() {
      if (dialog) {
        dialog.classList.remove('opacity-100');
        setTimeout(() => {
          dialog.classList.add('hidden');
        }, 500);
      }
    }

    closeBtn?.addEventListener('click', closeDialog);

    // Close on background click
    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) closeDialog();
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && dialog && !dialog.classList.contains('hidden')) {
        closeDialog();
      }
    });
  });
</script>

<style>
  #hidden-message-dialog.opacity-100 {
    opacity: 1 !important;
  }
</style>
