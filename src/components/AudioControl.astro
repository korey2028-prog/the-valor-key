---
// AudioControl: 最朴素的 HTML5 audio 标签播放预合成的 WAV
// 跳过所有 Web Audio API / Tone.js,直接用浏览器原生 audio,iOS / 微信 / 桌面统一兼容
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0, -1) : import.meta.env.BASE_URL;
const audioSrc = `${base}/audio/city-of-stars-loop.wav`;
---

<!-- Audio control button (top-right corner) -->
<div class="fixed top-6 right-6 z-40">
  <button
    id="audio-toggle"
    class="glass rounded-full p-3 hover:scale-110 transition-transform focus:outline-none focus:ring-2 focus:ring-tiffany focus:ring-offset-2"
    aria-label="Toggle background music"
    aria-pressed="false"
  >
    <svg id="icon-muted" class="w-6 h-6 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M11 5L6 9H2v6h4l5 4V5z"/>
      <line x1="23" y1="9" x2="17" y2="15"/>
      <line x1="17" y1="9" x2="23" y2="15"/>
    </svg>
    <svg id="icon-playing" class="w-6 h-6 text-tiffany hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M9 18V5l12-2v13"/>
      <circle cx="6" cy="18" r="3"/>
      <circle cx="18" cy="16" r="3"/>
    </svg>
    <svg id="icon-loading" class="w-6 h-6 text-tiffany hidden animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="10" stroke-opacity="0.25"/>
      <path d="M12 2a10 10 0 0 1 10 10"/>
    </svg>
  </button>
</div>

<!-- 实际的 audio 元素 - 关键: playsinline + preload="auto" 让 iOS 行为最稳 -->
<audio
  id="bg-music"
  src={audioSrc}
  loop
  preload="auto"
  playsinline
  webkit-playsinline="true"
></audio>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const audio = document.getElementById('bg-music') as HTMLAudioElement | null;
    const toggleBtn = document.getElementById('audio-toggle');
    const iconMuted = document.getElementById('icon-muted');
    const iconPlaying = document.getElementById('icon-playing');
    const iconLoading = document.getElementById('icon-loading');

    if (!audio || !toggleBtn) return;

    // 默认音量 - 50% 适中
    audio.volume = 0.5;

    function showIcon(name: 'muted' | 'playing' | 'loading') {
      iconMuted?.classList.toggle('hidden', name !== 'muted');
      iconPlaying?.classList.toggle('hidden', name !== 'playing');
      iconLoading?.classList.toggle('hidden', name !== 'loading');
    }

    // 监听 audio 事件 - 状态同步
    audio.addEventListener('play', () => {
      showIcon('playing');
      toggleBtn?.setAttribute('aria-pressed', 'true');
    });

    audio.addEventListener('pause', () => {
      showIcon('muted');
      toggleBtn?.setAttribute('aria-pressed', 'false');
    });

    audio.addEventListener('waiting', () => {
      showIcon('loading');
    });

    audio.addEventListener('error', (e) => {
      console.error('Audio error:', audio.error);
      alert(`Audio error code: ${audio.error?.code}\nMessage: ${audio.error?.message || 'unknown'}`);
      showIcon('muted');
    });

    toggleBtn.addEventListener('click', () => {
      if (audio.paused) {
        // 关键: play() 必须在 user gesture 同步调用
        showIcon('loading');
        const playPromise = audio.play();

        if (playPromise) {
          playPromise
            .then(() => {
              showIcon('playing');
            })
            .catch((err) => {
              console.error('Play failed:', err);
              alert(`无法播放: ${err.name}\n${err.message}`);
              showIcon('muted');
            });
        }
      } else {
        audio.pause();
      }
    });
  });
</script>
