---
// AudioControl: 用 Tone.js 生成温暖的电钢琴式 ambient pad loop
// - PolySynth(FMSynth) 模拟温暖钢琴音色
// - Reverb + Low-pass filter 增加空间感和柔和度
// - 4 个和弦循环(Em → D → C → Bm)
// - 自动处理 iOS / WeChat 浏览器的 audio unmute
---

<!-- Floating audio control button in top-right corner -->
<div class="fixed top-6 right-6 z-40">
  <button
    id="audio-toggle"
    class="glass rounded-full p-3 hover:scale-110 transition-transform focus:outline-none focus:ring-2 focus:ring-tiffany focus:ring-offset-2"
    aria-label="Toggle background music"
    aria-pressed="false"
  >
    <!-- Muted icon (default) -->
    <svg id="icon-muted" class="w-6 h-6 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M11 5L6 9H2v6h4l5 4V5z"/>
      <line x1="23" y1="9" x2="17" y2="15"/>
      <line x1="17" y1="9" x2="23" y2="15"/>
    </svg>
    <!-- Playing icon -->
    <svg id="icon-playing" class="w-6 h-6 text-tiffany hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M9 18V5l12-2v13"/>
      <circle cx="6" cy="18" r="3"/>
      <circle cx="18" cy="16" r="3"/>
    </svg>
    <!-- Loading icon -->
    <svg id="icon-loading" class="w-6 h-6 text-tiffany hidden animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="10" stroke-opacity="0.25"/>
      <path d="M12 2a10 10 0 0 1 10 10"/>
    </svg>
  </button>
</div>

<script>
  import * as Tone from 'tone';

  document.addEventListener('DOMContentLoaded', () => {
    const toggleBtn = document.getElementById('audio-toggle');
    const iconMuted = document.getElementById('icon-muted');
    const iconPlaying = document.getElementById('icon-playing');
    const iconLoading = document.getElementById('icon-loading');

    let isPlaying = false;
    let isInitialized = false;
    let synth: Tone.PolySynth | null = null;
    let loop: Tone.Loop | null = null;
    let chordIndex = 0;

    // Chord progression: Em → D → C → Bm (warm minor progression)
    // Each chord = 4 notes (root + voicings)
    const chords: string[][] = [
      ['E2', 'E3', 'G3', 'B3'],   // Em
      ['D2', 'D3', 'F#3', 'A3'],  // D
      ['C2', 'C3', 'E3', 'G3'],   // C
      ['B1', 'B2', 'D3', 'F#3'],  // Bm
    ];

    function showIcon(name: 'muted' | 'playing' | 'loading') {
      iconMuted?.classList.toggle('hidden', name !== 'muted');
      iconPlaying?.classList.toggle('hidden', name !== 'playing');
      iconLoading?.classList.toggle('hidden', name !== 'loading');
    }

    async function initAudio() {
      if (isInitialized) return;

      // 温暖的电钢琴式音色——用 FMSynth 模拟
      synth = new Tone.PolySynth(Tone.FMSynth, {
        harmonicity: 1.2,
        modulationIndex: 2.5,
        oscillator: { type: 'sine' },
        modulation: { type: 'sine' },
        envelope: {
          attack: 0.8,
          decay: 1.2,
          sustain: 0.4,
          release: 3.5,
        },
        modulationEnvelope: {
          attack: 0.3,
          decay: 0.1,
          sustain: 0.8,
          release: 1.5,
        },
      });

      // 效果链: Reverb(空间感) → Filter(柔和) → Destination
      const reverb = new Tone.Reverb({
        decay: 7,
        wet: 0.55,
      });
      await reverb.generate(); // 生成 reverb impulse response

      const filter = new Tone.Filter({
        type: 'lowpass',
        frequency: 1600,
        rolloff: -12,
        Q: 0.4,
      });

      synth.chain(reverb, filter, Tone.Destination);

      // 主音量 (dB) ——比 Web Audio API 0.15 要安静很多
      Tone.Destination.volume.value = -18;

      // BPM 慢一些,呼吸感
      Tone.Transport.bpm.value = 50;

      // 每个和弦持续时间(4n = 一拍,约 1.2s @ 50bpm; 2n = 半小节,约 2.4s)
      loop = new Tone.Loop((time) => {
        if (synth) {
          synth.triggerAttackRelease(chords[chordIndex], '2n', time);
          chordIndex = (chordIndex + 1) % chords.length;
        }
      }, '2n');

      isInitialized = true;
    }

    async function startMusic() {
      try {
        showIcon('loading');

        // iOS / WeChat 关键: Tone.start() 必须在 user gesture 内调用
        await Tone.start();

        await initAudio();

        if (loop) {
          chordIndex = 0;
          loop.start(0);
          Tone.Transport.start();
        }

        isPlaying = true;
        showIcon('playing');
        toggleBtn?.setAttribute('aria-pressed', 'true');
      } catch (err) {
        console.error('Audio start failed:', err);
        showIcon('muted');
      }
    }

    function stopMusic() {
      if (loop) {
        loop.stop();
      }
      Tone.Transport.stop();
      Tone.Transport.cancel();

      isPlaying = false;
      showIcon('muted');
      toggleBtn?.setAttribute('aria-pressed', 'false');
    }

    toggleBtn?.addEventListener('click', async () => {
      if (isPlaying) {
        stopMusic();
      } else {
        await startMusic();
      }
    });
  });
</script>
